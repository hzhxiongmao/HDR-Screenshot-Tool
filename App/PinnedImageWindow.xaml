<Window x:Class="HDRScreenshotTool.PinnedImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Topmost="True" ShowInTaskbar="False"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize">
    <Grid Background="Transparent"
          MouseLeftButtonDown="Grid_MouseLeftButtonDown"
          MouseWheel="Grid_MouseWheel"
          MouseRightButtonUp="Grid_MouseRightButtonUp"
          KeyDown="Window_KeyDown">
        <Image x:Name="ImgPinned" Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               IsHitTestVisible="False"/>
        <Button x:Name="BtnClose" Content="✕"
                Width="26" Height="26" FontSize="14"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="3"
                Background="#99333333" Foreground="#CCFFFFFF"
                BorderThickness="0" Cursor="Hand"
                Click="BtnClose_Click"
                MouseEnter="BtnClose_MouseEnter"
                MouseLeave="BtnClose_MouseLeave"/>
    </Grid>
</Window>
