<Window x:Class="HDRScreenshotTool.PinnedImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Topmost="True" ShowInTaskbar="False"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize" SizeToContent="WidthAndHeight">
    <Grid>
        <Image x:Name="ImgPinned" Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               MouseLeftButtonDown="Image_MouseLeftButtonDown"
               MouseWheel="Image_MouseWheel"
               MouseRightButtonUp="Image_MouseRightButtonUp"
               MouseEnter="Image_MouseEnter"
               MouseLeave="Image_MouseLeave"/>
        <!-- Close button, shown on hover -->
        <Button x:Name="BtnClose" Content="✕"
                Width="24" Height="24" FontSize="14"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="4"
                Background="#CC333333" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                Visibility="Collapsed"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
