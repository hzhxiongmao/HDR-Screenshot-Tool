<Window x:Class="HDRScreenshotTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDR Screenshot"
        Width="380" Height="620" MinWidth="340" MinHeight="500"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Closing="Window_Closing" StateChanged="Window_StateChanged">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <StackPanel>
                <TextBlock x:Name="TxtTitle" Text="HDR Screenshot" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <Button x:Name="BtnCapture" Content="Capture Region" Height="40" FontSize="14"
                        FontWeight="SemiBold" Margin="10,5" Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnCapture_Click"/>

                <!-- Hotkey -->
                <Expander x:Name="ExpHotkey" Header="Hotkey" IsExpanded="False"
                          Margin="0,3,0,0" FontSize="12">
                    <StackPanel Margin="0,5,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtHotkey" Text="Ctrl+Shift+S" IsReadOnly="True"
                                     FontSize="14" TextAlignment="Center" VerticalContentAlignment="Center"
                                     Height="30" Background="#F0F0F0"/>
                            <Button Grid.Column="1" x:Name="BtnSetHotkey" Content="Set" Width="50"
                                    Height="30" Margin="5,0,0,0" Click="SetHotkey_Click"/>
                        </Grid>
                        <TextBlock x:Name="LblHotkeyHint" Text="Click Set then press key combo"
                                   FontSize="10" Foreground="Gray" Margin="0,3,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Expander>

                <!-- Adjustments -->
                <Expander x:Name="ExpAdjust" Header="Adjustments" IsExpanded="False"
                          Margin="0,3,0,0" FontSize="12">
                    <StackPanel Margin="0,5,0,0">
                        <TextBlock x:Name="LblContrastName" Text="Contrast" FontSize="11" Margin="0,2,0,0"/>
                        <Slider x:Name="SldContrast" Minimum="0" Maximum="200" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblContrast" Text="1.00" FontSize="10" Foreground="Gray"
                                   HorizontalAlignment="Right"/>

                        <TextBlock x:Name="LblSaturationName" Text="Saturation" FontSize="11" Margin="0,5,0,0"/>
                        <Slider x:Name="SldSaturation" Minimum="0" Maximum="300" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblSaturation" Text="1.00" FontSize="10" Foreground="Gray"
                                   HorizontalAlignment="Right"/>

                        <TextBlock x:Name="LblBrightnessName" Text="Brightness" FontSize="11" Margin="0,5,0,0"/>
                        <Slider x:Name="SldBrightness" Minimum="-100" Maximum="100" Value="0"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblBrightness" Text="0" FontSize="10" Foreground="Gray"
                                   HorizontalAlignment="Right"/>

                        <TextBlock x:Name="LblGammaName" Text="Gamma" FontSize="11" Margin="0,5,0,0"/>
                        <Slider x:Name="SldGamma" Minimum="50" Maximum="300" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblGamma" Text="1.00" FontSize="10" Foreground="Gray"
                                   HorizontalAlignment="Right"/>

                        <Button x:Name="BtnReset" Content="Reset" Height="28" FontSize="11"
                                Margin="0,8,0,0" Click="ResetSettings_Click"/>
                    </StackPanel>
                </Expander>

                <!-- Save folder -->
                <TextBlock x:Name="LblSaveFolder" Text="Save to folder" FontSize="11"
                           Margin="10,10,0,2"/>
                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSaveFolder" FontSize="11"
                             VerticalContentAlignment="Center" Height="26"
                             Background="#F0F0F0" TextWrapping="NoWrap"
                             LostFocus="TxtSaveFolder_LostFocus"/>
                    <Button Grid.Column="1" x:Name="BtnBrowse" Content="Browse..." Width="60"
                            Height="26" FontSize="11" Margin="5,0,0,0" Click="BtnBrowse_Click"/>
                </Grid>

                <!-- Save options -->
                <CheckBox x:Name="ChkSaveToFile" Content="Save to file" FontSize="11"
                          Margin="10,6,0,0"
                          Checked="ChkSaveToFile_Changed" Unchecked="ChkSaveToFile_Changed"/>
                <CheckBox x:Name="ChkCopyToClipboard" Content="Copy to clipboard" FontSize="11"
                          Margin="10,2,0,0"
                          Checked="ChkCopyToClipboard_Changed" Unchecked="ChkCopyToClipboard_Changed"/>

                <!-- Language -->
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="LblLanguage" Text="Language:" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbLanguage" Width="110" Height="26" FontSize="11"
                              SelectionChanged="CmbLanguage_Changed">
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="中文" Tag="zh"/>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="ChkStartup" Content="Start with Windows"
                          FontSize="11" Margin="10,10,0,0" HorizontalAlignment="Center"
                          Checked="ChkStartup_Changed" Unchecked="ChkStartup_Changed"/>

                <TextBlock x:Name="TxtStatus" Text="Ready" FontSize="11" Foreground="Gray"
                           HorizontalAlignment="Center" Margin="0,10,0,5"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
