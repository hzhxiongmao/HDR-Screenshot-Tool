<Window x:Class="HDRScreenshotTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDR Screenshot"
        Width="340" Height="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Closing="Window_Closing" StateChanged="Window_StateChanged">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="HDR Screenshot" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <Button x:Name="BtnCapture" Content="Capture Region" Height="40" FontSize="14" FontWeight="SemiBold"
                    Margin="10,5" Background="#0078D4" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Click="BtnCapture_Click"/>

            <Button Content="Minimize to Tray" Height="30" FontSize="11"
                    Margin="10,2" BorderThickness="0" Cursor="Hand"
                    Background="#E0E0E0" Click="Minimize_Click"/>

            <Expander Header="Hotkey" IsExpanded="False" Margin="0,3,0,0" FontSize="12">
                <StackPanel Margin="0,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtHotkey" Text="Ctrl+Shift+S" IsReadOnly="True"
                                 FontSize="14" TextAlignment="Center" VerticalContentAlignment="Center" Height="30"
                                 Background="#F0F0F0"/>
                        <Button Grid.Column="1" Content="Set" Width="50" Height="30" Margin="5,0,0,0" Click="SetHotkey_Click"/>
                    </Grid>
                    <TextBlock x:Name="LblHotkeyHint" Text="Click Set then press key combo" FontSize="10" Foreground="Gray" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Expander>

            <Expander Header="Adjustments" IsExpanded="False" Margin="0,3,0,0" FontSize="12">
                <StackPanel Margin="0,5,0,0">
                    <TextBlock Text="Contrast" FontSize="11" Margin="0,2,0,0"/>
                    <Slider x:Name="SldContrast" Minimum="0" Maximum="200" Value="100" TickFrequency="10" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblContrast" Text="1.00" FontSize="10" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock Text="Saturation" FontSize="11" Margin="0,5,0,0"/>
                    <Slider x:Name="SldSaturation" Minimum="0" Maximum="300" Value="100" TickFrequency="10" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblSaturation" Text="1.00" FontSize="10" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock Text="Brightness" FontSize="11" Margin="0,5,0,0"/>
                    <Slider x:Name="SldBrightness" Minimum="-100" Maximum="100" Value="0" TickFrequency="5" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblBrightness" Text="0" FontSize="10" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock Text="Gamma" FontSize="11" Margin="0,5,0,0"/>
                    <Slider x:Name="SldGamma" Minimum="50" Maximum="300" Value="100" TickFrequency="10" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblGamma" Text="1.00" FontSize="10" Foreground="Gray" HorizontalAlignment="Right"/>
                    <Button Content="Reset" Height="28" FontSize="11" Margin="0,8,0,0" Click="ResetSettings_Click"/>
                </StackPanel>
            </Expander>

            <CheckBox x:Name="ChkStartup" Content="Start with Windows"
                      FontSize="11" Margin="10,5,0,0"
                      HorizontalAlignment="Center"
                      Checked="ChkStartup_Changed" Unchecked="ChkStartup_Changed"/>

            <TextBlock x:Name="TxtStatus" Text="Ready" FontSize="11" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
